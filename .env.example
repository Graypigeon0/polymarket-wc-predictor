# =========================
# Database (Supabase)
# =========================
# Get from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...
# For psql migrations (Supabase project settings > Database > Connection string)
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# =========================
# LLM (Mistral primary — EU-based, works in Cyprus)
# =========================
# Required. Get from: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your-mistral-key-here
MISTRAL_MODEL=mistral-small-latest

# Optional alternatives (may be blocked in some regions)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# =========================
# Telegram alerts
# =========================
# From @BotFather on Telegram: /newbot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Send a message to your bot, then:
# curl https://api.telegram.org/bot<TOKEN>/getUpdates
# Look for "chat":{"id": ...}
TELEGRAM_CHAT_ID=123456789

# =========================
# Sports data
# =========================
# Free tier: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# =========================
# Polymarket
# =========================
# CLOB API is public/free; no key needed unless placing trades
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# =========================
# Runtime
# =========================
LOG_LEVEL=INFO
ENVIRONMENT=development  # development | production
EDGE_ALERT_THRESHOLD=0.0  # any positive edge
EDGE_ALERT_COOLDOWN_MINUTES=30
